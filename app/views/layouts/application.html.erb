<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ruflet | Build multi-platform apps in Ruby" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Ruflet is a Ruby UI framework for building realtime web, mobile, and desktop apps from one codebase.">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ruflet">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-950 text-slate-100 antialiased">
    <% if flash[:notice].present? || flash[:alert].present? %>
      <div class="pointer-events-none fixed inset-x-0 top-4 z-50 flex justify-center px-4" data-controller="toast">
        <% if flash[:notice].present? %>
          <div class="pointer-events-auto rounded-2xl border border-emerald-400/25 bg-emerald-500/15 px-5 py-3 text-sm font-semibold text-emerald-100 shadow-[0_18px_40px_rgba(16,185,129,0.18)] backdrop-blur transition duration-150" data-toast-target="message">
            <%= flash[:notice] %>
          </div>
        <% elsif flash[:alert].present? %>
          <div class="pointer-events-auto rounded-2xl border border-rose-400/25 bg-rose-500/15 px-5 py-3 text-sm font-semibold text-rose-100 shadow-[0_18px_40px_rgba(244,63,94,0.18)] backdrop-blur transition duration-150" data-toast-target="message">
            <%= flash[:alert] %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
