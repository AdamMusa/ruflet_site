<section class="relative overflow-hidden bg-slate-950">
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <%= link_to "ruflet", root_path, class: "text-xl font-black lowercase tracking-[0.22em] text-white" %>
    <nav class="hidden items-center gap-8 text-sm font-medium text-slate-300 md:flex">
      <%#= link_to "Docs", docs_path, class: "transition hover:text-white" %>
      <a href="https://github.com/AdamMusa/Ruflet" target="_blank" rel="noreferrer" class="transition hover:text-white" aria-label="GitHub"><%= github_icon %></a>
    </nav>
  </div>

  <div class="mx-auto grid w-full max-w-7xl gap-16 px-6 pb-16 pt-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:pb-24 lg:pt-12">
    <%= image_tag "ruflet.png", alt: "Ruflet", class: "rounded-sm object-contain" %>
    <div class="order-1 lg:order-2">
      <h1 class="max-w-[9ch] text-5xl font-black tracking-[-0.06em] text-sky-400 sm:text-6xl lg:text-7xl">Build multi-platform apps in Ruby</h1>
      <p class="mt-8 max-w-xl text-2xl leading-[1.8] text-slate-300">Easily build realtime web, mobile, and desktop apps in pure Ruby. No frontend framework switch required.</p>
      <div class="mt-10 flex flex-wrap gap-4">
        <%= link_to "Get Started", "https://github.com/AdamMusa/Ruflet", target: "_", class: "inline-flex min-h-14 items-center justify-center rounded-2xl bg-[#cc342d] px-10 text-xl font-bold text-white shadow-[0_18px_40px_rgba(204,52,45,0.32)] transition hover:-translate-y-0.5 hover:bg-[#b22d27]" %>
      </div>
    </div>
  </div>
</section>

<section id="features" class="bg-slate-950 px-6 py-20 text-slate-100 lg:px-8">
  <div class="mx-auto w-full max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex rounded-full border border-sky-400/20 bg-sky-400/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-sky-300">Awesome features</span>
      <h2 class="mt-5 text-4xl font-black tracking-[-0.05em] sm:text-5xl">Everything you need to build with Ruflet</h2>
      <p class="mt-5 text-lg leading-8 text-slate-300">A Tailwind-powered marketing layout inspired by the Flet homepage, adapted for Ruflet and Ruby.</p>
    </div>

    <div class="mt-12 grid gap-x-10 gap-y-12 md:grid-cols-2 xl:grid-cols-3">
      <% @features.each do |feature| %>
        <article class="space-y-4 text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-400/10 text-sky-300">
            <%= feature_icon(feature[:icon]) %>
          </div>
          <h3 class="text-2xl font-bold tracking-[-0.03em]"><%= feature[:title] %></h3>
          <p class="text-base leading-8 text-slate-300"><%= feature[:body] %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>
